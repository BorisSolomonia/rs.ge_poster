CAMORA_BOG_API_STATEMENT_RETRY_DELAY_MILLIS=750
CAMORA_BOG_API_STATEMENT_CHUNK_DAYS=31
CAMORA_BOG_API_LARGE_CREDIT_THRESHOLD=1000.00
