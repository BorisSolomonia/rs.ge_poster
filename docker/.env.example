# Backend
APP_SERVER_PORT=8080
APP_MAX_FILE_SIZE=50MB
APP_MAX_REQUEST_SIZE=55MB
CAMORA_API_PREFIX=/api/v1
CAMORA_LOG_LEVEL=INFO
CAMORA_CONFIG_DIR=/data/camora
CAMORA_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://<VM_PUBLIC_IP>
CAMORA_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CAMORA_CORS_ALLOWED_HEADERS=*
CAMORA_CORS_ALLOW_CREDENTIALS=false
CAMORA_CORS_MAX_AGE_SECONDS=3600

# Local JSON stores
CAMORA_SUPPLIER_MAPPINGS_FILE=supplier-mappings.json
CAMORA_PRODUCT_MAPPINGS_FILE=product-mappings.json
CAMORA_STANDALONE_SUPPLIERS_FILE=standalone-suppliers.json
CAMORA_SALES_PRODUCT_EXCLUSIONS_FILE=sales-product-exclusions.json
CAMORA_SALES_EVENTS_FILE=sales-events.json
CAMORA_CASH_FLOW_CATEGORY_MAPPINGS_FILE=cash-flow-category-mappings.json
CAMORA_BANK_TRANSACTION_MAPPINGS_FILE=bank-transaction-mappings.json
CAMORA_SUPPLIER_PAYMENT_MAPPINGS_FILE=supplier-payment-mappings.json
CAMORA_SUPPLIER_CASH_PAYMENTS_FILE=supplier-cash-payments.json
CAMORA_SUPPLIER_DEBT_SNAPSHOT_FILE=supplier-debt-snapshot.json
CAMORA_SUPPLIER_CREDITORS_FILE=supplier-creditors.json
CAMORA_RSGE_PURCHASE_LEDGER_FILE=rsge-purchase-ledger.json

# General business settings
CAMORA_ORGANIZATION_OPENING_DATE=2025-01-01
CAMORA_MATCH_THRESHOLD=0.01
CAMORA_RESULT_CACHE_MAX_SIZE=20
CAMORA_RESULT_CACHE_EXPIRE_AFTER_HOURS=12
CAMORA_RECONCILIATION_RESULT_EXPIRE_AFTER_HOURS=12
CAMORA_SUPPLIER_DEBT_SOURCE_CACHE_TTL_MINUTES=60
CAMORA_SUPPLIER_DEBT_SOURCE_CACHE_MAX_SIZE=32
CAMORA_SUPPLIER_DEBT_BOG_STATEMENT_WINDOW_DAYS=0
CAMORA_SUPPLIER_DEBT_SCHEDULED_SYNC_ENABLED=true
CAMORA_SUPPLIER_DEBT_SYNC_FIXED_DELAY=3600000
CAMORA_SUPPLIER_DEBT_SYNC_INITIAL_DELAY=60000
CAMORA_PLATFORM_RSGE=RSGE
CAMORA_PLATFORM_POSTER=POSTER
CAMORA_SEED_ENABLED=false
CAMORA_SEED_RESOURCE=

# RS.ge API
CAMORA_RSGE_ENDPOINT=https://services.rs.ge/WayBillService/WayBillService.asmx
CAMORA_RSGE_USERNAME=
CAMORA_RSGE_PASSWORD=
CAMORA_RSGE_BUYER_TIN=
CAMORA_RSGE_WAYBILL_TYPES=2,5
CAMORA_RSGE_TIMEOUT_SECONDS=120
CAMORA_RSGE_DEBUG=false
CAMORA_RSGE_DEBUG_SAMPLE_COUNT=3
CAMORA_RSGE_DEBUG_RESPONSE_SNIPPET_LENGTH=0

# Sales analysis
CAMORA_SALES_ANALYSIS_MATCH_THRESHOLD=0.01
CAMORA_SALES_ANALYSIS_WEEK_STARTS_ON_ISO=1
CAMORA_SALES_ANALYSIS_EXCLUSIONS_SEED_RESOURCE=classpath:seed/sales_product_exclusions.txt
CAMORA_SALES_ANALYSIS_SUGGESTION_LIMIT=8
CAMORA_SALES_ANALYSIS_MAX_SUGGESTION_DISTANCE=3

# Cash flow Google Sheet integration
CAMORA_CASH_FLOW_ENABLED=false
CAMORA_CASH_FLOW_SHEET_ID=
CAMORA_CASH_FLOW_SHEET_NAME=
CAMORA_CASH_FLOW_RANGE=
CAMORA_CASH_FLOW_SOURCE_START_ROW=2
CAMORA_CASH_FLOW_SYNC_FIXED_DELAY=14400000
CAMORA_CASH_FLOW_SERVICE_ACCOUNT_JSON=
CAMORA_CASH_FLOW_SERVICE_ACCOUNT_PATH=
CAMORA_CASH_FLOW_WARNING_NEGATIVE_BALANCE_THRESHOLD=0.00
CAMORA_CASH_FLOW_INCOME_KEYWORDS=income,revenue,sale,service,services
CAMORA_CASH_FLOW_EXPENSE_KEYWORDS=expense,expenses,material,materials,inventory,stock,purchase,purchases,service cost,opex
CAMORA_CASH_FLOW_SAFE_KEYWORDS=safe,transfer,internal,deposit,withdrawal
CAMORA_CASH_FLOW_DIVIDEND_KEYWORDS=dividend,dividends

# Spreadsheet import columns
CAMORA_CASH_FLOW_COL_CATEGORY=0
CAMORA_CASH_FLOW_COL_DAY=1
CAMORA_CASH_FLOW_COL_MONTH=2
CAMORA_CASH_FLOW_COL_YEAR=3
CAMORA_CASH_FLOW_COL_COUNTERPARTY=4
CAMORA_CASH_FLOW_COL_MATERIAL_VALUE=5
CAMORA_CASH_FLOW_COL_SERVICE_VALUE=6
CAMORA_CASH_FLOW_COL_CASH_INFLOW=7
CAMORA_CASH_FLOW_COL_CASH_OUTFLOW=8
CAMORA_CASH_FLOW_COL_CASH_BALANCE=9
CAMORA_CASH_FLOW_COL_BOG_INFLOW=10
CAMORA_CASH_FLOW_COL_BOG_OUTFLOW=11
CAMORA_CASH_FLOW_COL_BOG_BALANCE=12
CAMORA_CASH_FLOW_COL_TBC_INFLOW=13
CAMORA_CASH_FLOW_COL_TBC_OUTFLOW=14
CAMORA_CASH_FLOW_COL_TBC_BALANCE=15
CAMORA_CASH_FLOW_COL_COMMENT=16
CAMORA_CASH_FLOW_COL_FULL_DATE=17
CAMORA_CASH_FLOW_COL_VALIDATION_FLAG=18
CAMORA_SALES_SHEET_INDEX=0
CAMORA_SALES_SKIP_HEADER_ROWS=1
CAMORA_SALES_MIN_COLUMNS=8
CAMORA_SALES_DATE_FORMAT=yyyy-MM-dd
CAMORA_SALES_COL_DATE=1
CAMORA_SALES_COL_PRODUCT=2
CAMORA_SALES_COL_AMOUNT=7
CAMORA_SALES_COL_QUANTITY=4
CAMORA_SALES_COL_PROFIT=8
CAMORA_TBC_SHEET_INDEX=1
CAMORA_TBC_SKIP_HEADER_ROWS=1
CAMORA_TBC_MIN_COLUMNS=5
CAMORA_TBC_DATE_FORMAT=dd.MM.yyyy
CAMORA_TBC_COL_DATE=0
CAMORA_TBC_COL_AMOUNT=4
CAMORA_BOG_SHEET_INDEX=0
CAMORA_BOG_SKIP_HEADER_ROWS=1
CAMORA_BOG_MIN_COLUMNS=5
CAMORA_BOG_DATE_FORMAT=dd.MM.yyyy
CAMORA_BOG_COL_DATE=0
CAMORA_BOG_COL_AMOUNT=4

# TBC DBI bank API
CAMORA_TBC_DBI_ENABLED=false
CAMORA_TBC_DBI_ENDPOINT=https://secdbi.tbconline.ge/dbi/dbiService
CAMORA_TBC_DBI_USERNAME=
CAMORA_TBC_DBI_PASSWORD=
CAMORA_TBC_DBI_CERTIFICATE_PATH=
CAMORA_TBC_DBI_CERTIFICATE_BASE64=
CAMORA_TBC_DBI_CERTIFICATE_PASSWORD=
CAMORA_TBC_DBI_ACCOUNT_NUMBER=
CAMORA_TBC_DBI_CURRENCY=GEL
CAMORA_TBC_DBI_PAGE_SIZE=700
CAMORA_TBC_DBI_TIMEOUT_SECONDS=120
CAMORA_TBC_DBI_LARGE_CREDIT_THRESHOLD=1000.00

# BOG Business Online API
CAMORA_BOG_API_ENABLED=false
CAMORA_BOG_API_TOKEN_URL=https://account.bog.ge/auth/realms/bog/protocol/openid-connect/token
CAMORA_BOG_API_BASE_URL=https://api.businessonline.ge/api
CAMORA_BOG_API_CLIENT_ID=
CAMORA_BOG_API_CLIENT_SECRET=
CAMORA_BOG_API_ACCOUNT_NUMBER=
CAMORA_BOG_API_CURRENCY=GEL
CAMORA_BOG_API_TAKE=1000
