# Backend
APP_SERVER_PORT=8080
CAMORA_API_PREFIX=/api/v1
CAMORA_LOG_LEVEL=INFO
CAMORA_CONFIG_DIR=/data/camora
CAMORA_SUPPLIER_MAPPINGS_FILE=supplier-mappings.json
CAMORA_PRODUCT_MAPPINGS_FILE=product-mappings.json
CAMORA_STANDALONE_SUPPLIERS_FILE=standalone-suppliers.json
CAMORA_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://<VM_PUBLIC_IP>
CAMORA_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CAMORA_CORS_ALLOWED_HEADERS=*
CAMORA_CORS_ALLOW_CREDENTIALS=false
CAMORA_CORS_MAX_AGE_SECONDS=3600
CAMORA_SEED_ENABLED=true
CAMORA_SEED_RESOURCE=classpath:seed/supplier_mapping.csv
CAMORA_MATCH_THRESHOLD=0.01
CAMORA_RESULT_CACHE_MAX_SIZE=20
CAMORA_RESULT_CACHE_EXPIRE_AFTER_HOURS=12
CAMORA_RECONCILIATION_RESULT_EXPIRE_AFTER_HOURS=12
CAMORA_PLATFORM_RSGE=RSGE
CAMORA_PLATFORM_POSTER=POSTER
CAMORA_RSGE_ENDPOINT=https://services.rs.ge/WayBillService/WayBillService.asmx
CAMORA_RSGE_USERNAME=
CAMORA_RSGE_PASSWORD=
CAMORA_RSGE_TIMEOUT_SECONDS=120
CAMORA_RSGE_DEBUG=false
CAMORA_RSGE_DEBUG_SAMPLE_COUNT=3
CAMORA_RSGE_DEBUG_RESPONSE_SNIPPET_LENGTH=0
APP_MAX_FILE_SIZE=50MB
APP_MAX_REQUEST_SIZE=55MB
