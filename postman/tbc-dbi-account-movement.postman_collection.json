{
  "info": {
    "name": "TBC DBI Account Movement",
    "description": "Postman collection for testing TBC DBI SOAP GetAccountMovements with WS-Security username/password and a PFX client certificate configured in Postman settings.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "TBC DBI - GetAccountMovements by date range",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/xml; charset=utf-8",
            "type": "text"
          },
          {
            "key": "SOAPAction",
            "value": "{{tbc_dbi_soap_action}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "<soapenv:Envelope\n  xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\"\n  xmlns:myg=\"http://www.mygemini.com/schemas/mygemini\"\n  xmlns:wsse=\"http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd\">\n  <soapenv:Header>\n    <wsse:Security>\n      <wsse:UsernameToken>\n        <wsse:Username>{{tbc_dbi_username}}</wsse:Username>\n        <wsse:Password>{{tbc_dbi_password}}</wsse:Password>\n        <wsse:Nonce>{{tbc_dbi_nonce}}</wsse:Nonce>\n      </wsse:UsernameToken>\n    </wsse:Security>\n  </soapenv:Header>\n  <soapenv:Body>\n    <myg:GetAccountMovementsRequestIo>\n      <myg:accountMovementFilterIo>\n        <myg:pager>\n          <myg:pageIndex>{{tbc_dbi_page_index}}</myg:pageIndex>\n          <myg:pageSize>{{tbc_dbi_page_size}}</myg:pageSize>\n        </myg:pager>\n        <myg:accountNumber>{{tbc_dbi_account_number}}</myg:accountNumber>\n        <myg:accountCurrencyCode>{{tbc_dbi_currency}}</myg:accountCurrencyCode>\n        <myg:periodFrom>{{tbc_dbi_period_from}}</myg:periodFrom>\n        <myg:periodTo>{{tbc_dbi_period_to}}</myg:periodTo>\n      </myg:accountMovementFilterIo>\n    </myg:GetAccountMovementsRequestIo>\n  </soapenv:Body>\n</soapenv:Envelope>",
          "options": {
            "raw": {
              "language": "xml"
            }
          }
        },
        "url": {
          "raw": "{{tbc_dbi_base_url}}",
          "host": [
            "{{tbc_dbi_base_url}}"
          ]
        },
        "description": "Uses the documented TBC DBI SOAP Account Movement request. Configure the PFX certificate in Postman settings before sending."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is SOAP XML', function () {",
              "  pm.expect(pm.response.text()).to.include('Envelope');",
              "});",
              "",
              "pm.test('No SOAP fault', function () {",
              "  pm.expect(pm.response.text()).to.not.include('Fault');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Camora - Bank Analysis via backend",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{camora_base_url}}{{camora_api_prefix}}/bank-analysis/tbc?dateFrom={{camora_date_from}}&dateTo={{camora_date_to}}",
          "host": [
            "{{camora_base_url}}"
          ],
          "path": [
            "{{camora_api_prefix}}",
            "bank-analysis",
            "tbc"
          ],
          "query": [
            {
              "key": "dateFrom",
              "value": "{{camora_date_from}}"
            },
            {
              "key": "dateTo",
              "value": "{{camora_date_to}}"
            }
          ]
        },
        "description": "Use this after the app env is configured. It calls the Camora backend endpoint that wraps TBC DBI movements."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Camora response wrapper exists', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('success');",
              "  pm.expect(body).to.have.property('data');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
